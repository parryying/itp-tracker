# Azure Blob Storage — for patient photo uploads
# Photos go straight to Azure, never saved to phone album
EXPO_PUBLIC_AZURE_STORAGE_ACCOUNT_NAME=itptrackerstorage
EXPO_PUBLIC_AZURE_STORAGE_CONTAINER_NAME=patient-photos
EXPO_PUBLIC_AZURE_STORAGE_SAS_TOKEN=your-sas-token-here

# Azure OpenAI — for clinical reasoning and bruise detection (planned)
EXPO_PUBLIC_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
EXPO_PUBLIC_AZURE_OPENAI_KEY=your-key-here
EXPO_PUBLIC_AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Epic MyChart — for lab auto-sync (planned)
EXPO_PUBLIC_EPIC_CLIENT_ID=your-client-id
EXPO_PUBLIC_EPIC_REDIRECT_URI=itptracker://auth/callback
